rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: eigen profiel lezen/schrijven, admin alles
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
      allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Content: publiek lezen, klant en admin schrijven
    match /content/{document=**} {
      allow read: if true;
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                   || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'klant';
    }

    // Aanvragen: publiek aanmaken, auth lezen/updaten
    match /aanvragen/{id} {
      allow create: if true;
      allow read, update: if request.auth != null;
    }

    // Afspraken: auth vereist
    match /afspraken/{id} {
      allow read, write: if request.auth != null;
    }

    // Portfolio: publiek lezen, auth schrijven
    match /portfolio/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Producten: publiek lezen, auth schrijven
    match /producten/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Documenten: auth vereist
    match /documenten/{id} {
      allow read, write: if request.auth != null;
    }

    // Reviews: publiek lezen, auth schrijven
    match /reviews/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Config: publiek lezen, alleen admin schrijven
    match /config/{document=**} {
      allow read: if true;
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
